---
import { Icon } from "astro-icon/components";
import { SOCIALS } from "@/config";
---

<div class="flex gap-2">
  {
    SOCIALS.map((networkS) =>
      networkS.show && (
        <a
          class="text-cli-text-muted hover:text-cli-green transition-colors duration-150 p-1.5 rounded-sm hover:bg-cli-surface border border-transparent hover:border-cli-border"
          href={networkS.url}
          target="_blank"
          aria-label={networkS.name + " link"}
        >
          <Icon name={networkS.icon} class="w-4 h-4" />
        </a>
      )
    )
  }
</div>
