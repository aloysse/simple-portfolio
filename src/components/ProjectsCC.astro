---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const allProjects = await getCollection("projects");
const sorted = allProjects.sort((a, b) => a.id.localeCompare(b.id));
---

<section class="mt-6 w-full font-mono">
  <!-- Prompt -->
  <div class="flex items-center gap-2 text-xs mb-5">
    <span class="text-cli-green">$</span>
    <span class="text-cli-text-muted">ls -la projects/</span>
  </div>

  <!-- Project grid -->
  <div class="grid grid-cols-1 gap-4 cli-stagger">
    {
      sorted.map((project) => (
        <ProjectCard
          id={project.id}
          title={project.data.title}
          summary={project.data.summary}
          tags={project.data.tags}
          cover={project.data.cover}
        />
      ))
    }
  </div>
</section>
