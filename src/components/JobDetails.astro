---
import { formatDatetime } from "../lib/utils";

interface Job {
  title: string;
  company: string;
  location: string;
  startDate: string;
  endDate: string;
  description: string;
  goals: string[];
  currentJob: boolean;
}

const { jobData } = Astro.props;
const { title, company, location, startDate, endDate, description, goals, currentJob } = jobData as Job;

const dateRange = `${formatDatetime(startDate)} → ${currentJob ? "Present" : formatDatetime(endDate)}`;
---

<div class="border-l-2 border-cli-border pl-4 flex flex-col gap-2 hover:border-cli-green transition-colors duration-200">
  <!-- Title -->
  <div class="flex items-center gap-2">
    <span class="text-cli-green text-xs">▶</span>
    <h3 class="text-cli-text font-bold text-sm">{title}</h3>
    {currentJob && <span class="text-xs text-cli-green border border-cli-green/30 px-1.5 py-0.5 rounded-sm">now</span>}
  </div>

  <!-- Meta -->
  <div class="flex flex-wrap items-center gap-x-2 gap-y-0.5 text-xs text-cli-text-muted">
    <span class="text-cli-amber">{dateRange}</span>
    {company && <><span>·</span><span>{company}</span></>}
    {location && <><span>·</span><span>{location}</span></>}
  </div>

  <!-- Description -->
  {description && (
    <p class="text-xs text-cli-text-dim leading-relaxed">{description}</p>
  )}

  <!-- Goals -->
  {goals.length > 0 && (
    <ul class="flex flex-col gap-1 mt-1">
      {goals.map((goal: string) => (
        <li class="flex items-start gap-2 text-xs text-cli-text-dim">
          <span class="text-cli-green mt-0.5 flex-shrink-0">›</span>
          <span>{goal}</span>
        </li>
      ))}
    </ul>
  )}
</div>
