---
import { menu } from "../data/menu";

const pathname = Astro.url.pathname;
---

<nav class="bg-cli-surface border-b border-cli-border fixed w-full z-20 top-0 start-0" id="menu">
  <div class="max-w-screen-xl flex items-center justify-between mx-auto px-4 h-11">

    <!-- Window chrome + path -->
    <a href="/" class="flex items-center gap-3 group">
      <div class="flex gap-1.5 items-center">
        <span class="w-3 h-3 rounded-full bg-cli-red opacity-90 group-hover:opacity-100 transition-opacity"></span>
        <span class="w-3 h-3 rounded-full bg-cli-yellow opacity-90 group-hover:opacity-100 transition-opacity"></span>
        <span class="w-3 h-3 rounded-full bg-cli-green opacity-90 group-hover:opacity-100 transition-opacity"></span>
      </div>
      <span class="text-cli-text-muted text-xs font-mono hidden sm:inline">~/minshiou</span>
    </a>

    <!-- Desktop nav -->
    <div class="hidden md:flex items-center gap-6" id="navbar-sticky">
      {
        menu.map((item) => (
          <a
            href={item.href}
            class:list={{
              "font-mono text-xs transition-colors duration-150 px-2 py-1 rounded": true,
              "text-cli-green border border-cli-green/30 bg-cli-green/5": pathname === item.href,
              "text-cli-text-dim hover:text-cli-text border border-transparent hover:border-cli-border": pathname !== item.href,
            }}
          >
            <span class="text-cli-text-muted">--</span>{item.label.toLowerCase()}
          </a>
        ))
      }
    </div>

    <!-- Mobile menu button -->
    <button
      id="btn-menu"
      type="button"
      class="md:hidden text-cli-text-muted hover:text-cli-green transition-colors p-1.5"
      aria-label="Toggle menu"
    >
      <svg id="icon-open" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg id="icon-close" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>

  </div>

  <!-- Mobile menu -->
  <div class="md:hidden hidden border-t border-cli-border bg-cli-bg" id="mobile-nav">
    <div class="px-4 py-3 flex flex-col gap-1">
      {
        menu.map((item) => (
          <a
            href={item.href}
            class:list={{
              "font-mono text-sm py-2 px-3 rounded transition-colors": true,
              "text-cli-green bg-cli-green/10": pathname === item.href,
              "text-cli-text-dim hover:text-cli-text hover:bg-cli-surface": pathname !== item.href,
            }}
          >
            <span class="text-cli-text-muted mr-1">$</span> {item.label.toLowerCase()}
          </a>
        ))
      }
    </div>
  </div>
</nav>

<script>
  function initNav() {
    const btn = document.getElementById("btn-menu");
    const mobileNav = document.getElementById("mobile-nav");
    const iconOpen = document.getElementById("icon-open");
    const iconClose = document.getElementById("icon-close");

    btn?.addEventListener("click", () => {
      const isHidden = mobileNav?.classList.contains("hidden");
      mobileNav?.classList.toggle("hidden");
      iconOpen?.classList.toggle("hidden", !isHidden);
      iconClose?.classList.toggle("hidden", isHidden);
    });
  }

  initNav();
  document.addEventListener("astro:after-swap", initNav);
</script>
