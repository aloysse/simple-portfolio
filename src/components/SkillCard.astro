---
import { Icon } from "astro-icon/components";

interface SkillCardProps {
  icon: string;
  name: string;
  description: string;
  showDescription?: boolean;
}

const { icon, name, description, showDescription = true } = Astro.props as SkillCardProps;
---

<div class="flex items-start gap-3 border border-cli-border bg-cli-surface rounded-sm p-3
            hover:border-cli-green/40 hover:bg-cli-surface-2 transition-all duration-200 group">
  <div class="flex-shrink-0 w-7 h-7 flex items-center justify-center">
    <Icon
      width={24}
      height={24}
      name={icon}
      class="text-cli-green group-hover:text-cli-green-bright transition-colors"
    />
  </div>
  <div class="flex flex-col gap-0.5 min-w-0">
    <h3 class="text-cli-text text-xs font-bold">{name}</h3>
    {showDescription && description && (
      <p class="text-cli-text-muted text-xs leading-relaxed">{description}</p>
    )}
  </div>
</div>
