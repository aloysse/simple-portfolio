---
import { getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import Layout from "../../layouts/Layout.astro";
import BackBtn from "@/components/BackBtn.astro";

export async function getStaticPaths() {
  const posts = await getCollection("projects");
  return posts.map((post) => ({
    params: { id: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { title, summary, tags, cover, ogImage, url } = post.data;
const { Content } = await render(post);
---

<Layout title={title} description={summary} imageOg={ogImage} scrollSmooth={true}>
  <main class="container py-24 flex flex-col gap-8 font-mono" id="top">

    <!-- Back button -->
    <div class="flex justify-start mt-6">
      <BackBtn />
    </div>

    <!-- Header -->
    <div class="flex flex-col gap-3">
      <div class="flex items-center gap-2 text-xs text-cli-text-muted">
        <span class="text-cli-green">$</span>
        <span>cat projects/{post.id}.md</span>
      </div>

      <h1 class="text-cli-text text-2xl font-bold">
        <span class="text-cli-green">▶ </span>{title}
      </h1>

      <!-- Tags -->
      <div class="flex flex-wrap gap-1.5">
        {tags.map((tag: string) => (
          <span class="text-cli-text-muted text-xs border border-cli-border px-2 py-0.5 rounded-sm">
            {tag}
          </span>
        ))}
      </div>
    </div>

    <!-- Cover image -->
    <div class="border border-cli-border rounded-sm overflow-hidden bg-cli-surface relative">
      <!-- Terminal chrome bar -->
      <div class="flex items-center gap-1.5 px-3 h-8 bg-cli-surface-2 border-b border-cli-border">
        <span class="w-2.5 h-2.5 rounded-full bg-cli-red opacity-70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-cli-yellow opacity-70"></span>
        <span class="w-2.5 h-2.5 rounded-full bg-cli-green opacity-70"></span>
        <span class="ml-2 text-cli-text-muted text-xs">{title}</span>
      </div>
      <Image
        transition:name={`${post.id}-image`}
        class="w-full"
        src={cover}
        alt="Main project image"
      />
    </div>

    <!-- Summary -->
    <div class="border-l-2 border-cli-green pl-4">
      <p class="text-cli-text-dim text-sm leading-relaxed">{summary}</p>
    </div>

    <!-- Project URL -->
    {url && (
      <div class="flex items-center gap-2 text-xs">
        <span class="text-cli-green">$</span>
        <span class="text-cli-text-muted">open</span>
        <a
          href={url}
          target="_blank"
          class="text-cli-blue hover:text-cli-green hover:underline transition-colors"
        >
          {url} ↗
        </a>
      </div>
    )}

    <!-- Article content -->
    <article class="prose max-w-none mt-4">
      <Content />
    </article>

    <!-- Back to top -->
    <div class="flex justify-center mt-8 pb-4">
      <button
        id="back-to-top"
        class="inline-flex items-center gap-2 font-mono text-xs text-cli-text-muted
               border border-cli-border px-3 py-2 rounded-sm
               hover:border-cli-green hover:text-cli-green
               transition-all duration-200"
      >
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-3.5 h-3.5">
          <path d="M13.0001 7.82843V20H11.0001V7.82843L5.63614 13.1924L4.22192 11.7782L12.0001 4L19.7783 11.7782L18.3641 13.1924L13.0001 7.82843Z"/>
        </svg>
        scroll-to-top
      </button>
    </div>

  </main>
</Layout>

<script is:inline>
  function backToTop() {
    document.querySelector("#back-to-top")?.addEventListener("click", () => {
      document.body.scrollTop = 0;
      document.documentElement.scrollTop = 0;
    });
  }
  backToTop();
</script>
