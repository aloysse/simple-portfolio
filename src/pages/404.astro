---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Not Found" description="The page you are looking for cannot be found." scrollSmooth={false}>
  <main class="container flex-grow flex justify-center items-center font-mono" role="main">
    <div class="flex flex-col items-center gap-4 text-center py-20">
      <div class="text-cli-text-muted text-xs flex items-center gap-2 mb-2">
        <span class="text-cli-red">✗</span>
        <span>bash: page: command not found</span>
      </div>
      <h1 class="text-7xl font-bold text-cli-green cli-glow">404</h1>
      <p class="text-cli-text-dim text-sm">
        <span class="text-cli-amber">Error:</span> Page not found
      </p>
      <a
        href="/"
        class="mt-4 inline-flex items-center gap-2 border border-cli-border text-cli-text-muted px-4 py-2 text-xs rounded-sm
               hover:border-cli-green hover:text-cli-green transition-all duration-200"
      >
        <span class="text-cli-green">$</span>
        cd ~
      </a>
    </div>
  </main>
</Layout>
